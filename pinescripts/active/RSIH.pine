//@version=6
// ─────────────────────────────────────────────────────────────────────────────
//  RSIH  —  RSI MA Strategy indicator
//  Shared engine imported from TradeHLib.
// ─────────────────────────────────────────────────────────────────────────────
indicator(title = 'RSI MA Strat', shorttitle = 'RSIMA', format = format.price)

import harshad_inarkar/TradeHLib/13 as THL

source = close

// ── RSI level lines (display only — not in library) ───────────────────────────
const float hl = 66.7
const float ml = 50.0
const float ll = 33.3

// ── RSI signal — calc_RSI_raw returns [smoothrsi, sig_rsiMA, status_code] ──────
// Uses the same linreg-based trend detection as the Strategy and Scanner.
// Previously used a simple 3-bar slope comparison — replaced with the
// library's more robust angle+linreg version for consistency across all scripts.
[rsiMA, sig_rsiMA, rsi_status_code] = THL.calc_RSI(source)

// ── Decode signal → colour and text ───────────────────────────────────────────
[_, col] = THL.decodeStratCode(rsi_status_code)
bgcolor(col)

// ── Level lines ───────────────────────────────────────────────────────────────
hline(hl, title = 'Upper Line', linewidth = 2, linestyle = hline.style_dotted, color = color.yellow)
hline(ml, title = 'Middle Line', linewidth = 2, linestyle = hline.style_dotted, color = color.red)
hline(ll, title = 'Lower Line', linewidth = 2, linestyle = hline.style_dotted, color = color.blue)

// ── Plots ─────────────────────────────────────────────────────────────────────
plot(rsiMA,     linewidth = 2, color = color.aqua, title = 'RSI MA')
plot(sig_rsiMA, linewidth = 2, color = color.red,  title = 'Signal')
