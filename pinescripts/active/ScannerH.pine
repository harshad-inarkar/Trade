//@version=6
// ─────────────────────────────────────────────────────────────────────────────
//  Scanner  —  multi-symbol signal scanner
//  Shared engine imported from StrategyLib.
// ─────────────────────────────────────────────────────────────────────────────
indicator(title = 'Scanner', shorttitle = 'Scan', overlay = true)

import harshad_inarkar/TradeHLib/13 as THL

// ── Sources ───────────────────────────────────────────────────────────────────
source = close
volsrc = volume

// ── Inputs ────────────────────────────────────────────────────────────────────
var use_vol_kst          = input(true,  'Use Volume Indicator')
var secret               = input('',    title = 'Secret')
var alert_type           = input.string('no_order', title = 'Alert Type',
                             options = ['no_order','basket_order','deltaexch_order','regular_order'])
var ignore_exit_alert    = input(true,  'Ignore Exit Alert')
var basket_map           = input('',    title = 'Basket Map')
var symb_bask_arr        = str.split(basket_map, ' ')


var lineup_check               = input.int(2, title = 'Lineup Check',         options = [0,2,3,4])
var ma_filter                  = input.int(2, title = 'MA Filter',            options = [1,2,3,4])
var strict_confirm_trade_check = input.int(0, title = 'Strict confirm trade', options = [0,1,2,3])
var long_signal_flag           = input(true,  title = 'Long Signal')
var short_signal_flag          = input(true,  title = 'Short Signal')
var tf1_alert                  = input(true,  title = 'tf1 Alert')

const float negative_threshold       = -0.1
const float maxp_threshold           = 0.1
const float prof_strength_threshold  = 10
var exclude_negatives        = input(true,  title = 'Exclude Negative Position')
var exclude_low_strength     = input(false, title = 'Exclude Low Strength Position')
var show_only_maxp_threshold = input(false, title = 'Show only maxp threshold Position')
var int top_symb             = input(40,    title = 'Recent Alerts Only')

var last_n_days      = input.float(0, 'Days')
var last_hrs         = input.float(9, 'Hours')
var show_only_window = input(false, title = 'Show trades in window')

var start   = THL.calc_window_start(show_only_window,last_n_days, last_hrs)

window() => time >= start

var show_stats = input(false, title = 'Show stats')
var sortby     = input.string('avg_maxp', title = 'Sort by',    options = ['tot_maxp','avg_maxp','win_rate'])
var sort_order = input.string('Desc',     title = 'Sort order', options = ['Desc','Asc'])



var symbolsInput = input.text_area("BANKNIFTY\nNIFTY_MID_SELECT\nNIFTY", "Symbols")
const int maxSymbols   = 40

// ── Bar-state helpers ─────────────────────────────────────────────────────────
last_bar_update = barstate.isconfirmed and (barstate.islast or barstate.islastconfirmedhistory)
show_stats_bar  = show_stats and last_bar_update


// ── Security Symbols-chart MAs ────────────────────────────────────────────────────────────
[out1,out2,out3,out4] = THL.get_all_mas(source)

out1_trend = THL.get_osc_trend(out1)
out2_trend = THL.get_osc_trend(out2)

lineup_status = THL.calc_lineup_status(out1, out2, out3, out4)

// ── Alert text templates ──────────────────────────────────────────────────────
const string comm_bask_txt  = '"secret":"{0}","alertType":"basket","basket_id":"{1}"'
const string comm_delta_txt = '"symbol":"{0}","side":"{1}","qty":"{2}","trigger_time":"{3}","strategy_id":"{4}"'


// ─────────────────────────────────────────────────────────────────────────────
//  Security-context screener function
//  Runs inside request.security — uses library for all signal computation
// ─────────────────────────────────────────────────────────────────────────────
get_all_status_codes() =>
    final_st = THL.calc_final_summary(
         source, volsrc,
         out1, out2, out3, out4,
         out1_trend, out2_trend,
         use_vol_kst, long_signal_flag, short_signal_flag,
         lineup_check, ma_filter,
         window())

    final_st := strict_confirm_trade_check != 0 ?
                     THL.calc_trigger_entry(
                         final_st, source,
                         strict_confirm_trade_check, barstate.isconfirmed) :
                         final_st

    ltp = source

    actual_close_time = 0
    actual_close_time := THL.is_entry_exit(final_st) ? time_close : actual_close_time[1]

    // All P&L accumulation delegated to library
    [entry_val, curr_prof, maxp, trades, total_maxp, win_trades, _ap] =
         THL.calc_trade_stats(final_st, source, show_stats_bar)

    [lineup_status, entry_val, ltp, actual_close_time, final_st,
      curr_prof, maxp, trades, total_maxp, win_trades]

// ─────────────────────────────────────────────────────────────────────────────
//  UDTs
// ─────────────────────────────────────────────────────────────────────────────
type stats_row
    string symbol
    int    trades
    float  total_maxp
    int    win_trades

type alert_row
    string symbol
    float  entry
    float  ltp
    float  prof
    float  maxp
    color  sig
    int    time_alert

type status_row
    string symbol
    int    status
    float  ltp
    int    t_close
    int    lineup_st
    float  entry
    float  prof
    float  maxp

enum UDTtype
    ALERT
    STATS

var array<alert_row>  alerts_arr        = array.new<alert_row>()
var array<stats_row>  stats_arr         = array.new<stats_row>()
var array<status_row> symbol_status_arr = array.new<status_row>()

// ── Insertion sort ────────────────────────────────────────────────────────────
get_alert_sort_key_val(ao) => ao.time_alert

get_stats_sort_key_val(so) =>
    switch sortby
        'tot_maxp'  => so.total_maxp
        'avg_maxp'  => so.trades == 0 ? 0.0 : so.total_maxp / so.trades
        =>             so.trades == 0 ? 0.0 : float(so.win_trades) / so.trades


build_udt_keys(UDTtype udtyp) =>
    keys = array.new<float>()
    switch udtyp
        UDTtype.ALERT =>
            for i = 0 to array.size(alerts_arr) - 1
                array.push(keys, get_alert_sort_key_val(array.get(alerts_arr, i)))
        UDTtype.STATS =>
            for i = 0 to array.size(stats_arr) - 1
                array.push(keys, get_stats_sort_key_val(array.get(stats_arr, i)))
    keys


sort_udt_arr(udt_arr, UDTtype udtyp, udt_sort_ord = 'Asc') =>
    n = array.size(udt_arr)
    if n > 1
        keys = build_udt_keys(udtyp)
        for i = 1 to n - 1
            key_i = array.get(keys,    i)
            val_i = array.get(udt_arr, i)
            j     = i - 1
            while j >= 0
                key_j        = array.get(keys, j)
                should_shift = udt_sort_ord == 'Desc' ? key_j < key_i : key_j > key_i
                if not should_shift
                    break
                array.set(keys,    j + 1, key_j)
                array.set(udt_arr, j + 1, array.get(udt_arr, j))
                j := j - 1
            array.set(keys,    j + 1, key_i)
            array.set(udt_arr, j + 1, val_i)

// ─────────────────────────────────────────────────────────────────────────────
//  Symbol list initialisation
// ─────────────────────────────────────────────────────────────────────────────
var symbolArray = str.split(symbolsInput, "\n")
var symbolsset  = array.new_string()
var actualCount = 0

if barstate.isconfirmed and barstate.isfirst
    for i = 0 to array.size(symbolArray) - 1
        cleanSym = str.trim(str.replace(array.get(symbolArray, i), "\r", ""))
        if cleanSym != '' and array.indexof(symbolsset, cleanSym) == -1
            array.push(symbolsset, cleanSym)
    actualCount := math.min(array.size(symbolsset), maxSymbols)

// ─────────────────────────────────────────────────────────────────────────────
//  Security calls
// ─────────────────────────────────────────────────────────────────────────────
if barstate.isconfirmed
    if show_stats_bar
        array.clear(stats_arr)
    if last_bar_update
        array.clear(symbol_status_arr)
        array.clear(alerts_arr)

    for i = 0 to actualCount - 1
        cleanSym = array.get(symbolsset, i)

        [lineup_st, entry_val, ltp, actual_close_time, final_st, curr_prof, maxp, trades, total_maxp, win_trades] =
                 request.security(cleanSym, timeframe.period,
                                     get_all_status_codes(), ignore_invalid_symbol = true)

        if last_bar_update and not na(final_st)
            array.push(symbol_status_arr,
                        status_row.new(cleanSym, final_st, ltp, actual_close_time,
                                       lineup_st, entry_val, curr_prof, maxp))
            if show_stats_bar
                array.push(stats_arr,
                            stats_row.new(cleanSym, trades, total_maxp, win_trades))

// ─────────────────────────────────────────────────────────────────────────────
//  Alert helpers
// ─────────────────────────────────────────────────────────────────────────────
get_alert_info(actual_close_time, st, value, symb) =>
    [dis_txt, dis_col] = THL.decodeStratCode(st)
    any_alert = THL.is_entry_exit(st)
    symb_info = symb + THL.sep + dis_txt + THL.sep + str.tostring(value) + THL.line_sep
    [any_alert, symb_info, dis_col]


add_alert_arr(symb, lineup_st, summ_trend_code, entry_val, ltp,
              curr_prof, maxp, summ_col, actual_close_time) =>
    if summ_trend_code != THL.STRAT_NEUTRAL
        array.push(alerts_arr,
                   alert_row.new(symb + THL.sep + str.tostring(lineup_st),
                                 entry_val, ltp, curr_prof, maxp,
                                 summ_col, actual_close_time))


get_basket_ids(s_name) =>
    long_id = ''  , exit_long_id  = ''
    short_id = '' , exit_short_id = ''
    if array.size(symb_bask_arr) > 0
        for i = 0 to array.size(symb_bask_arr) - 1
            ele_arr = str.split(array.get(symb_bask_arr, i), '|')
            if array.size(ele_arr) < 5
                continue
            if array.get(ele_arr, 0) == s_name
                long_id       := array.get(ele_arr, 1)
                exit_long_id  := array.get(ele_arr, 2)
                short_id      := array.get(ele_arr, 3)
                exit_short_id := array.get(ele_arr, 4)
                break
    [long_id, exit_long_id, short_id, exit_short_id]


get_deltaexch_ids(s_name) =>
    ticker_id = ''
    qty       = ''
    if array.size(symb_bask_arr) > 0
        for i = 0 to array.size(symb_bask_arr) - 1
            ele_arr = str.split(array.get(symb_bask_arr, i), '|')
            if array.size(ele_arr) < 3
                continue
            if array.get(ele_arr, 0) == s_name
                ticker_id := array.get(ele_arr, 1)
                qty       := array.get(ele_arr, 2)
                break
    [ticker_id, qty]


any_trade_alert = false
string scr_label = na


raise_order_alerts() =>
    symb_ele_arr = str.split(scr_label, THL.line_sep)
    if array.size(symb_ele_arr) > 0
        for i = 0 to array.size(symb_ele_arr) - 2
            symb_inf_arr = str.split(array.get(symb_ele_arr, i), THL.sep)
            s_name  = array.get(symb_inf_arr, 0)
            dis_txt = array.get(symb_inf_arr, 1)

            long_basket_txt       = ''
            exit_long_basket_txt  = ''
            short_basket_txt      = ''
            exit_short_basket_txt = ''

            if alert_type == 'basket_order'
                [long_id, exit_long_id, short_id, exit_short_id] = get_basket_ids(s_name)
                long_basket_txt       := '{' + str.format(comm_bask_txt, secret, long_id)       + '}'
                exit_long_basket_txt  := '{' + str.format(comm_bask_txt, secret, exit_long_id)  + '}'
                short_basket_txt      := '{' + str.format(comm_bask_txt, secret, short_id)      + '}'
                exit_short_basket_txt := '{' + str.format(comm_bask_txt, secret, exit_short_id) + '}'

            else if alert_type == 'deltaexch_order'
                [ticker_id, qty] = get_deltaexch_ids(s_name)
                ts = str.format_time(timenow)
                long_basket_txt       := '{' + str.format(comm_delta_txt, ticker_id, 'buy',  qty, ts, secret) + '}'
                exit_long_basket_txt  := '{' + str.format(comm_delta_txt, ticker_id, 'sell', qty, ts, secret) + '}'
                short_basket_txt      := '{' + str.format(comm_delta_txt, ticker_id, 'sell', qty, ts, secret) + '}'
                exit_short_basket_txt := '{' + str.format(comm_delta_txt, ticker_id, 'buy',  qty, ts, secret) + '}'

            ignore_alert = ignore_exit_alert and (dis_txt == 'XU' or dis_txt == 'XD')
            if not ignore_alert
                switch dis_txt
                    'U'  => alert(long_basket_txt,       freq = alert.freq_all)
                    'XU' => alert(exit_long_basket_txt,  freq = alert.freq_all)
                    'D'  => alert(short_basket_txt,      freq = alert.freq_all)
                    'XD' => alert(exit_short_basket_txt, freq = alert.freq_all)

// ─────────────────────────────────────────────────────────────────────────────
//  Main alert + table block
// ─────────────────────────────────────────────────────────────────────────────
if last_bar_update and tf1_alert

    symb_arr_size   = array.size(symbol_status_arr)
    any_trade_alert := false
    scr_label       := na

    for i = 0 to symb_arr_size - 1
        row = array.get(symbol_status_arr, i)
        [trade_alert_flag, symb_info, summ_col] =
             get_alert_info(row.t_close, row.status, row.ltp, row.symbol)

        if trade_alert_flag
            any_trade_alert := true
            scr_label       := scr_label + symb_info

        add_alert_arr(row.symbol, row.lineup_st, row.status,
                      row.entry,  row.ltp,       row.prof,
                      row.maxp,   summ_col,       row.t_close)

    if not na(scr_label) and any_trade_alert
        alert(THL.screener_sep + scr_label + THL.screener_sep, freq = alert.freq_once_per_bar_close)
        if alert_type != 'no_order'
            raise_order_alerts()

    sort_udt_arr(alerts_arr, UDTtype.ALERT, udt_sort_ord = 'Desc')
    arr_size = array.size(alerts_arr)

    var int num_col  = 6
    var int max_rows = math.min(actualCount, top_symb) + 1

    var table tbl1 = table.new(position.middle_left, num_col, max_rows,
                           frame_color = color(na), frame_width = 1,
                           border_width = 2, border_color = color(na))

    if arr_size > 0
        table.cell(tbl1, 0, 0, THL.format_time(time_close),  text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
        table.cell(tbl1, 1, 0, 'Entry', text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
        table.cell(tbl1, 2, 0, 'LTP',   text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
        table.cell(tbl1, 3, 0, 'Cur',   text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
        table.cell(tbl1, 4, 0, 'MaxP',  text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
        table.cell(tbl1, 5, 0, 'Time',  text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)

        cur_tb_row = 0
        for i = 0 to arr_size - 1
            ar = array.get(alerts_arr, i)

            if cur_tb_row >= top_symb
                break

            prof_strength = ar.maxp == 0 ? 100 :
                                     math.max(0, math.round((1 - (ar.maxp - ar.prof) / ar.maxp) * 100))
            if (exclude_negatives        and ar.prof <= negative_threshold)           or
               (exclude_low_strength     and prof_strength <= prof_strength_threshold) or
               (show_only_maxp_threshold and ar.maxp <= maxp_threshold)
                continue

            cur_tb_row += 1
            sig_col     = color.new(ar.sig, transp = 80)
            row_idx     = cur_tb_row

            table.cell(tbl1, 0, row_idx, ar.symbol,                   text_halign = text.align_left, bgcolor = sig_col,  text_color = color.white, text_size = size.small)
            table.cell(tbl1, 1, row_idx, str.tostring(ar.entry),      text_halign = text.align_left, bgcolor = color(na), text_color = color.white, text_size = size.small)
            table.cell(tbl1, 2, row_idx, str.tostring(ar.ltp),        text_halign = text.align_left, bgcolor = color(na), text_color = color.white, text_size = size.small)
            table.cell(tbl1, 3, row_idx, str.tostring(prof_strength), text_halign = text.align_left,
                        bgcolor = color.new(ar.sig, transp = 100 - prof_strength),
                        text_color = color.white, text_size = size.small)
            table.cell(tbl1, 4, row_idx, str.tostring(ar.maxp),       text_halign = text.align_left,
                        bgcolor = ar.maxp > 0.1 ? THL.greencol : color(na),
                        text_color = color.white, text_size = size.small)

            time_val = ar.time_alert
            time_str = dayofmonth(time_val,THL.india_tz) != dayofmonth(time_close,THL.india_tz) ?
                           THL.format_datetime(time_val) : THL.format_time(time_val)

            table.cell(tbl1, 5, row_idx, time_str, text_halign = text.align_left,
                        bgcolor = sig_col, text_color = color.white, text_size = size.small)

        if cur_tb_row < max_rows - 1
            table.clear(tbl1, 0, cur_tb_row + 1, num_col - 1, max_rows - 1)

    else
        table.clear(tbl1, 0, 0, num_col - 1, max_rows - 1)

// ─────────────────────────────────────────────────────────────────────────────
//  Stats table
// ─────────────────────────────────────────────────────────────────────────────
if show_stats_bar

    arr_size = array.size(stats_arr)
    if arr_size > 0
        sort_udt_arr(stats_arr, UDTtype.STATS, udt_sort_ord = sort_order)

        var tablecapsize = 20
        var cur_num_col  = 5
        var table tbl2   = na
        var table tbl3   = na

        tb_size = arr_size > tablecapsize ? 2 : 1
        for i = 0 to tb_size - 1
            cur_num_rows  = math.min(arr_size, tablecapsize) + 2
            cur_table_pos = position.middle_center
            table cur_tbl = na

            if i == 0
                if not na(tbl2)
                    table.delete(tbl2)
                    tbl2 := na
                tbl2    := table.new(cur_table_pos, cur_num_col, cur_num_rows,
                                     frame_color = color(na), frame_width = 1,
                                     border_width = 2, border_color = color(na))
                cur_tbl := tbl2
            else
                if not na(tbl3)
                    table.delete(tbl3)
                    tbl3 := na
                cur_table_pos := position.middle_right
                cur_num_rows  := arr_size - tablecapsize + 2
                tbl3    := table.new(cur_table_pos, cur_num_col, cur_num_rows,
                                     frame_color = color(na), frame_width = 1,
                                     border_width = 2, border_color = color(na))
                cur_tbl := tbl3

            hdr = THL.format_datetime(start) + ' to ' + THL.format_time(time_close)
            table.cell(cur_tbl, 0, 0, hdr,        text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
            table.cell(cur_tbl, 1, 0, 'Trades',   text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
            table.cell(cur_tbl, 2, 0, 'Maxp',     text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
            table.cell(cur_tbl, 3, 0, 'Maxp AVG', text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)
            table.cell(cur_tbl, 4, 0, 'WinRate',  text_halign = text.align_center, bgcolor = color.gray, text_color = color.white, text_size = size.small)

        allsymb_tr = 0, allsymb_mxp = 0.0, allsymb_wintr = 0

        for i = 0 to arr_size - 1
            sr       = array.get(stats_arr, i)
            cur_tbl  = tbl2
            row_indx = i
            if i >= tablecapsize
                cur_tbl  := tbl3
                row_indx := i - tablecapsize

            tr  = sr.trades
            mxp = sr.total_maxp
            wit = sr.win_trades
            allsymb_tr    += tr
            allsymb_mxp   += mxp
            allsymb_wintr += wit

            mxpavg = tr == 0 ? 0.0 : mxp / tr
            winrt  = tr == 0 ? 0.0 : float(wit) / tr

            table.cell(cur_tbl, 0, row_indx+1, sr.symbol,                           text_halign=text.align_left, bgcolor=color(na), text_color=color.white, text_size=size.small)
            table.cell(cur_tbl, 1, row_indx+1, str.tostring(tr),                    text_halign=text.align_left, bgcolor=color(na), text_color=color.white, text_size=size.small)
            table.cell(cur_tbl, 2, row_indx+1, str.tostring(math.round(mxp,    2)), text_halign=text.align_left, bgcolor=color(na), text_color=color.white, text_size=size.small)
            table.cell(cur_tbl, 3, row_indx+1, str.tostring(math.round(mxpavg, 2)), text_halign=text.align_left, bgcolor=color(na), text_color=color.white, text_size=size.small)
            table.cell(cur_tbl, 4, row_indx+1, str.tostring(math.round(winrt,  2)), text_halign=text.align_left, bgcolor=color(na), text_color=color.white, text_size=size.small)

            if i == arr_size - 1
                all_mxpavg = allsymb_tr == 0 ? 0.0 : allsymb_mxp / allsymb_tr
                all_winrt  = allsymb_tr == 0 ? 0.0 : float(allsymb_wintr) / allsymb_tr
                table.cell(cur_tbl, 0, row_indx+2, 'Total',                                    text_halign=text.align_left, bgcolor=color.gray, text_color=color.white, text_size=size.small)
                table.cell(cur_tbl, 1, row_indx+2, str.tostring(allsymb_tr),                   text_halign=text.align_left, bgcolor=color.gray, text_color=color.white, text_size=size.small)
                table.cell(cur_tbl, 2, row_indx+2, str.tostring(math.round(allsymb_mxp,  2)), text_halign=text.align_left, bgcolor=color.gray, text_color=color.white, text_size=size.small)
                table.cell(cur_tbl, 3, row_indx+2, str.tostring(math.round(all_mxpavg,   2)), text_halign=text.align_left, bgcolor=color.gray, text_color=color.white, text_size=size.small)
                table.cell(cur_tbl, 4, row_indx+2, str.tostring(math.round(all_winrt,    2)), text_halign=text.align_left, bgcolor=color.gray, text_color=color.white, text_size=size.small)
